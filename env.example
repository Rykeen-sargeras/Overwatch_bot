import crypto from 'node:crypto';
import type { BlacklistEntry } from '@prisma/client';
import path from 'node:path';
import { fileURLToPath } from 'node:url';
import express, { type Request, type Response } from 'express';
import rateLimit from 'express-rate-limit';
import session from 'express-session';
import helmet from 'helmet';
import {
  ChannelType,
  EmbedBuilder,
  PermissionFlagsBits,
} from 'discord.js';
import { client, getInviteUrl } from './bot.js';
import { config } from './config.js';
import { prisma } from './db.js';
import { getGuildHealth, queueSweep } from './enforcement.js';
import { escapeHtml, formatDate, page } from './html.js';
import {
  ensureCsrf,
  requireAuth,
  safeCompare,
  sessionCookieOptions,
  verifyCsrf,
} from './security.js';

const here = path.dirname(fileURLToPath(import.meta.url));
const publicDirectory = path.resolve(here, '../public');

function messageFrom(req: Request): string | undefined {
  return typeof req.query.message === 'string' ? req.query.message : undefined;
}

function redirectWithMessage(res: Response, pathName: string, message: string): void {
  const separator = pathName.includes('?') ? '&' : '?';
  res.redirect(`${pathName}${separator}message=${encodeURIComponent(message)}`);
}

export function createServer() {
  const app = express();
  app.set('trust proxy', 1);
  app.disable('x-powered-by');

  app.use(helmet({
    contentSecurityPolicy: {
      directives: {
        defaultSrc: ["'self'"],
        styleSrc: ["'self'"],
        imgSrc: ["'self'", 'https:', 'data:'],
      },
    },
  }));
  app.use(express.urlencoded({ extended: false, limit: '32kb' }));
  app.use(express.json({ limit: '32kb' }));
  app.use(express.static(publicDirectory));
  app.use(session({
    name: 'blacklist.sid',
    secret: config.sessionSecret,
    resave: false,
    saveUninitialized: false,
    cookie: sessionCookieOptions(),
  }));

  app.use(rateLimit({
    windowMs: 60_000,
    limit: 240,
    standardHeaders: 'draft-8',
    legacyHeaders: false,
  }));

  const loginLimiter = rateLimit({
    windowMs: 15 * 60_000,
    limit: 15,
    standardHeaders: 'draft-8',
    legacyHeaders: false,
  });

  app.get('/health', (_req, res) => {
    res.json({ ok: true, botReady: client.isReady() });
  });

  app.get('/login', (req, res) => {
    if (req.session.authenticated) {
      res.redirect('/');
      return;
    }
    const csrfToken = ensureCsrf(req);
    res.send(page({
      title: 'Log in',
      message: messageFrom(req),
      body: `
        <section class="login-card card">
          <h1>Open your moderation dashboard</h1>
          <p>Use the private admin password stored in Railway.</p>
          <form action="/login" method="post" class="stack">
            <input type="hidden" name="csrfToken" value="${escapeHtml(csrfToken)}">
            <label>Admin password
              <input name="password" type="password" required autocomplete="current-password">
            </label>
            <button type="submit">Log in</button>
          </form>
        </section>`,
    }));
  });

  app.post('/login', loginLimiter, verifyCsrf, (req, res) => {
    const password = String(req.body.password ?? '');
    if (!safeCompare(password, config.adminPassword)) {
      redirectWithMessage(res, '/login', 'Incorrect password.');
      return;
    }

    req.session.regenerate((error) => {
      if (error) {
        res.status(500).send('Could not start the session.');
        return;
      }
      req.session.authenticated = true;
      req.session.csrfToken = crypto.randomBytes(24).toString('hex');
      res.redirect('/');
    });
  });

  app.post('/logout', requireAuth, verifyCsrf, (req, res) => {
    req.session.destroy(() => res.redirect('/login'));
  });

  app.use(requireAuth);

  app.get('/', async (req, res) => {
    const csrfToken = ensureCsrf(req);
    const [activeEntries, enabledGuilds, successfulBans, failedActions] = await Promise.all([
      prisma.blacklistEntry.count({ where: { active: true } }),
      prisma.guildConfig.count({ where: { enabled: true } }),
      prisma.enforcementLog.count({ where: { action: 'BANNED', success: true } }),
      prisma.enforcementLog.count({ where: { success: false } }),
    ]);
    const inviteUrl = getInviteUrl();

    res.send(page({
      title: 'Dashboard',
      authenticated: true,
      csrfToken,
      message: messageFrom(req),
      body: `
        <div class="heading-row">
          <div><h1>Dashboard</h1><p>Manage the blacklist and every server from this page.</p></div>
          ${inviteUrl ? `<a class="button secondary" href="${escapeHtml(inviteUrl)}" target="_blank" rel="noreferrer">Add bot to a server</a>` : ''}
        </div>
        <section class="stats-grid">
          <article class="stat card"><span>Active blacklist</span><strong>${activeEntries}</strong></article>
          <article class="stat card"><span>Enabled servers</span><strong>${enabledGuilds}</strong></article>
          <article class="stat card"><span>Successful bans</span><strong>${successfulBans}</strong></article>
          <article class="stat card"><span>Failed actions</span><strong>${failedActions}</strong></article>
        </section>
        <section class="card">
          <h2>Safety status</h2>
          <p><span class="pill ${config.globalDryRun ? 'warning' : 'success'}">Global dry run: ${config.globalDryRun ? 'ON' : 'OFF'}</span></p>
          <p>${config.globalDryRun
            ? 'No real bans can happen. Change GLOBAL_DRY_RUN to false in Railway only after testing.'
            : 'Live enforcement is enabled. Each server can still keep its own dry-run switch on.'}</p>
          <p>Discord connection: <strong>${client.isReady() ? `Connected as ${escapeHtml(client.user?.tag)}` : 'Connecting…'}</strong></p>
        </section>`,
    }));
  });

  app.get('/blacklist', async (req, res) => {
    const csrfToken = ensureCsrf(req);
    const entries = await prisma.blacklistEntry.findMany({ orderBy: { updatedAt: 'desc' } });
    const rows = entries.map((entry: BlacklistEntry) => `
      <tr>
        <td><code>${escapeHtml(entry.userId)}</code><br><small>${escapeHtml(entry.username ?? 'Username unavailable')}</small></td>
        <td>${escapeHtml(entry.reason)}</td>
        <td><span class="pill ${entry.active ? 'danger' : ''}">${entry.active ? 'ACTIVE' : 'REMOVED'}</span></td>
        <td>${entry.successfulBans} / ${entry.failedBans}</td>
        <td>${formatDate(entry.updatedAt)}</td>
        <td class="actions">
          ${entry.active ? `
            <form action="/blacklist/${entry.id}/sweep" method="post">
              <input type="hidden" name="csrfToken" value="${escapeHtml(csrfToken)}">
              <button class="small secondary" type="submit">Sweep now</button>
            </form>
            <form action="/blacklist/${entry.id}/remove" method="post">
              <input type="hidden" name="csrfToken" value="${escapeHtml(csrfToken)}">
              <button class="small danger-button" type="submit">Remove</button>
            </form>` : ''}
        </td>
      </tr>`).join('');

    res.send(page({
      title: 'Blacklist',
      authenticated: true,
      csrfToken,
      message: messageFrom(req),
      body: `
        <div class="heading-row"><div><h1>Blacklist</h1><p>Add a permanent Discord user ID, not a username.</p></div></div>
        <section class="card">
          <h2>Add or reactivate a user</h2>
          <form action="/blacklist" method="post" class="form-grid">
            <input type="hidden" name="csrfToken" value="${escapeHtml(csrfToken)}">
            <label>Discord user ID
              <input name="userId" inputmode="numeric" pattern="[0-9]{17,20}" required placeholder="123456789012345678">
            </label>
            <label class="wide">Reason
              <textarea name="reason" required minlength="5" maxlength="1000" placeholder="Explain why this user is being blacklisted"></textarea>
            </label>
            <div class="wide"><button type="submit">Add to blacklist and check enabled servers</button></div>
          </form>
        </section>
        <section class="card table-card">
          <table>
            <thead><tr><th>User</th><th>Reason</th><th>Status</th><th>Bans / failures</th><th>Updated</th><th>Actions</th></tr></thead>
            <tbody>${rows || '<tr><td colspan="6">No blacklist entries yet.</td></tr>'}</tbody>
          </table>
        </section>`,
    }));
  });

  app.post('/blacklist', verifyCsrf, async (req, res) => {
    const userId = String(req.body.userId ?? '').trim();
    const reason = String(req.body.reason ?? '').trim();
    if (!/^\d{17,20}$/.test(userId) || reason.length < 5 || reason.length > 1000) {
      redirectWithMessage(res, '/blacklist', 'Enter a valid Discord ID and a reason of at least 5 characters.');
      return;
    }

    const discordUser = await client.users.fetch(userId).catch(() => null);
    const entry = await prisma.blacklistEntry.upsert({
      where: { userId },
      create: {
        userId,
        username: discordUser?.tag ?? null,
        reason,
        active: true,
      },
      update: {
        username: discordUser?.tag ?? undefined,
        reason,
        active: true,
        removedAt: null,
      },
    });
    queueSweep(entry);
    redirectWithMessage(res, '/blacklist', 'User added. Enabled servers are being checked.');
  });

  app.post('/blacklist/:id/remove', verifyCsrf, async (req, res) => {
    await prisma.blacklistEntry.update({
      where: { id: String(req.params.id) },
      data: { active: false, removedAt: new Date() },
    }).catch(() => null);
    redirectWithMessage(res, '/blacklist', 'Blacklist entry removed. Existing Discord bans are not automatically reversed.');
  });

  app.post('/blacklist/:id/sweep', verifyCsrf, async (req, res) => {
    const entry = await prisma.blacklistEntry.findUnique({ where: { id: String(req.params.id) } });
    if (entry?.active) queueSweep(entry, 'MANUAL');
    redirectWithMessage(res, '/blacklist', 'Enabled servers are being checked again.');
  });

  app.get('/servers', async (req, res) => {
    const csrfToken = ensureCsrf(req);
    const cards: string[] = [];

    for (const guild of client.guilds.cache.values()) {
      const guildConfig = await prisma.guildConfig.upsert({
        where: { guildId: guild.id },
        create: { guildId: guild.id, guildName: guild.name },
        update: { guildName: guild.name },
      });
      const health = await getGuildHealth(guild).catch(() => null);
      const botMember = await guild.members.fetchMe().catch(() => null);
      const channels = guild.channels.cache
        .filter((channel) => channel.type === ChannelType.GuildText || channel.type === ChannelType.GuildAnnouncement)
        .sort((a, b) => a.position - b.position)
        .map((channel) => {
          const canSend = botMember
            ? channel.permissionsFor(botMember)?.has([PermissionFlagsBits.ViewChannel, PermissionFlagsBits.SendMessages])
            : false;
          return `<option value="${channel.id}" ${guildConfig.logChannelId === channel.id ? 'selected' : ''}>#${escapeHtml(channel.name)}${canSend ? '' : ' (bot cannot send)'}</option>`;
        })
        .join('');

      cards.push(`
        <article class="card server-card">
          <div class="heading-row">
            <div><h2>${escapeHtml(guild.name)}</h2><code>${guild.id}</code></div>
            <span class="pill ${guildConfig.enabled ? 'success' : ''}">${guildConfig.enabled ? 'ENABLED' : 'DISABLED'}</span>
          </div>
          <p>Ban permission: <strong>${health?.hasBanPermission ? 'Yes' : 'No'}</strong> · Bot role: <strong>${escapeHtml(health?.botRoleName ?? 'Unknown')}</strong></p>
          <form action="/servers/${guild.id}" method="post" class="stack">
            <input type="hidden" name="csrfToken" value="${escapeHtml(csrfToken)}">
            <label class="checkbox"><input type="checkbox" name="enabled" ${guildConfig.enabled ? 'checked' : ''}> Enable blacklist enforcement in this server</label>
            <label class="checkbox"><input type="checkbox" name="dryRun" ${guildConfig.dryRun ? 'checked' : ''}> Server dry-run mode</label>
            <label>Discord log channel
              <select name="logChannelId">
                <option value="">No log channel</option>
                ${channels}
              </select>
            </label>
            <button type="submit">Save server settings</button>
          </form>
          ${guildConfig.logChannelId ? `
            <form action="/servers/${guild.id}/test-log" method="post" class="top-gap">
              <input type="hidden" name="csrfToken" value="${escapeHtml(csrfToken)}">
              <button class="secondary" type="submit">Send test log</button>
            </form>` : ''}
        </article>`);
    }

    res.send(page({
      title: 'Servers',
      authenticated: true,
      csrfToken,
      message: messageFrom(req),
      body: `
        <div class="heading-row"><div><h1>Servers</h1><p>Choose where enforcement runs and where logs are posted.</p></div></div>
        <section class="card warning-card"><strong>Role hierarchy:</strong> Move the bot’s Discord role above every role it may need to ban.</section>
        <section class="server-grid">${cards.join('') || '<div class="card">The bot is not in any servers yet.</div>'}</section>`,
    }));
  });

  app.post('/servers/:guildId', verifyCsrf, async (req, res) => {
    const guild = client.guilds.cache.get(String(req.params.guildId));
    if (!guild) {
      redirectWithMessage(res, '/servers', 'That server is not available to the bot.');
      return;
    }
    const logChannelId = String(req.body.logChannelId ?? '').trim() || null;
    if (logChannelId && !guild.channels.cache.has(logChannelId)) {
      redirectWithMessage(res, '/servers', 'The selected log channel is invalid.');
      return;
    }

    await prisma.guildConfig.upsert({
      where: { guildId: guild.id },
      create: {
        guildId: guild.id,
        guildName: guild.name,
        enabled: req.body.enabled === 'on',
        dryRun: req.body.dryRun === 'on',
        logChannelId,
      },
      update: {
        guildName: guild.name,
        enabled: req.body.enabled === 'on',
        dryRun: req.body.dryRun === 'on',
        logChannelId,
      },
    });
    redirectWithMessage(res, '/servers', `${guild.name} settings saved.`);
  });

  app.post('/servers/:guildId/test-log', verifyCsrf, async (req, res) => {
    const guild = client.guilds.cache.get(String(req.params.guildId));
    const guildConfig = await prisma.guildConfig.findUnique({ where: { guildId: String(req.params.guildId) } });
    if (!guild || !guildConfig?.logChannelId) {
      redirectWithMessage(res, '/servers', 'Configure a log channel first.');
      return;
    }
    const channel = guild.channels.cache.get(guildConfig.logChannelId);
    if (!channel?.isTextBased() || channel.isThread() || !('send' in channel)) {
      redirectWithMessage(res, '/servers', 'The bot cannot use that channel.');
      return;
    }
    await channel.send({
      embeds: [new EmbedBuilder().setTitle('Blacklist bot test').setDescription('The dashboard can post logs in this channel.').setTimestamp()],
      allowedMentions: { parse: [] },
    }).catch(() => null);
    redirectWithMessage(res, '/servers', 'Test log requested. Check the Discord channel.');
  });

  app.get('/logs', async (req, res) => {
    const csrfToken = ensureCsrf(req);
    const logs = await prisma.enforcementLog.findMany({
      orderBy: { createdAt: 'desc' },
      take: 200,
      include: { guild: true },
    });
    const rows = logs.map((log: { createdAt: Date; userId: string; action: string; success: boolean; details: string | null; guild: { guildName: string } }) => `
      <tr>
        <td>${formatDate(log.createdAt)}</td>
        <td>${escapeHtml(log.guild.guildName)}</td>
        <td><code>${escapeHtml(log.userId)}</code></td>
        <td><span class="pill ${log.success ? 'success' : 'warning'}">${escapeHtml(log.action)}</span></td>
        <td>${escapeHtml(log.details ?? '—')}</td>
      </tr>`).join('');

    res.send(page({
      title: 'Logs',
      authenticated: true,
      csrfToken,
      message: messageFrom(req),
      body: `
        <div class="heading-row"><div><h1>Enforcement logs</h1><p>The 200 most recent actions.</p></div></div>
        <section class="card table-card">
          <table>
            <thead><tr><th>Date</th><th>Server</th><th>User</th><th>Action</th><th>Details</th></tr></thead>
            <tbody>${rows || '<tr><td colspan="5">No enforcement logs yet.</td></tr>'}</tbody>
          </table>
        </section>`,
    }));
  });

  app.use((_req, res) => {
    res.status(404).send(page({ title: 'Not found', body: '<section class="card"><h1>Page not found</h1></section>' }));
  });

  app.use((error: unknown, _req: Request, res: Response, _next: unknown) => {
    console.error(error);
    res.status(500).send('Something went wrong. Check the Railway logs.');
  });

  return app;
}
